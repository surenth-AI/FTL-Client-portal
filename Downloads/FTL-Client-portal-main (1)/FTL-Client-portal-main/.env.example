# .env.example
# Copy this file to .env and configure your local or production values.
# DO NOT commit the .env file containing real passwords to Git!

# Flask Security Configurations
SECRET_KEY=enter-a-highly-secure-random-phrase-here

# Database Configuration (Azure SQL Server)
DB_SERVER=ftl.database.windows.net
DB_NAME=FTL_DEV
DB_USER=CloudSA465167d3
DB_PASSWORD=your_azure_database_password_here

# ODBC Driver Configurations:
# - On Local Windows development: Use '{SQL Server}' or '{ODBC Driver 17 for SQL Server}'
# - On Azure App Service (Linux Deployment): MUST use '{ODBC Driver 17 for SQL Server}' or '{ODBC Driver 18 for SQL Server}'
DB_DRIVER={SQL Server}
